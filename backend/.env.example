# DIBMS Backend Environment Variables
# Copy this file to .env and update values for your environment

# JWT Secret — MUST change for production
SECRET_KEY=change-me-to-a-random-64-char-string

# Database connection string
# SQLite (local development):
DATABASE_URL=sqlite:///./dibms.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@host:5432/dibms

# JWT token expiry in minutes (default: 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS allowed origins (comma-separated)
# Add your Vercel frontend URL for production
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# File upload directory
UPLOAD_DIR=uploads
